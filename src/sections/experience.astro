---
import Card from "@/components/Card.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const experiences = [
  { role: t("exp1Role"), company: t("exp1Company"), period: t("exp1Period"), logo: t("exp1Logo"), desc: t("exp1Desc") },
  { role: t("exp2Role"), company: t("exp2Company"), period: t("exp2Period"), logo: t("exp2Logo"), desc: t("exp2Desc") },
  { role: t("exp3Role"), company: t("exp3Company"), period: t("exp3Period"), logo: t("exp3Logo"), desc: t("exp3Desc") },
  { role: t("exp4Role"), company: t("exp4Company"), period: t("exp4Period"), logo: t("exp4Logo"), desc: t("exp4Desc") },
  { role: t("exp5Role"), company: t("exp5Company"), period: t("exp5Period"), logo: t("exp5Logo"), desc: t("exp5Desc") },
];
---

<section id="experience">
  <h2 class="section-title">{t("experienceTitle")}</h2>

  <div class="timeline">
    <div class="line"></div>
    {experiences.map((exp) => (
      <div class="exp-item">
        <div class="dot"></div>
        <Card class="card p-5 flex flex-col gap-2">
          <div class="exp-header">
            {exp.logo && <img src={exp.logo} alt="" class="exp-logo" loading="lazy" />}
            <div class="exp-meta">
              {exp.period && <span class="period">{exp.period}</span>}
              <h3 class="role">{exp.role}</h3>
              {exp.company && <p class="company">{exp.company}</p>}
            </div>
          </div>
          <p class="exp-desc">{exp.desc}</p>
        </Card>
      </div>
    ))}
  </div>


</section>

<style>
  section {
    padding: 60px 0 80px;
  }
  .section-title {
    font-size: 2rem;
    font-weight: 600;
    color: var(--text-purple);
    text-align: center;
    margin-bottom: 40px;
  }
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding-left: 40px;
  }
  .line {
    position: absolute;
    left: 15px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--line-gradient);
    border-radius: 1px;
  }
  .exp-item {
    position: relative;
  }
  .dot {
    position: absolute;
    left: -28px;
    top: 28px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgb(139,92,246);
    border: 2px solid var(--dot-border);
    box-shadow: 0 0 12px rgba(139,92,246,0.4);
  }
  .exp-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .exp-logo {
    width: 60px;
    height: 40px;
    border-radius: 6px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .exp-meta {
    flex: 1;
  }
  .period {
    font-size: 0.8rem;
    color: var(--text-period);
    font-weight: 500;
  }
  .role {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-purple);
    margin-top: 2px;
  }
  .company {
    font-size: 0.85rem;
    color: var(--text-purple);
    font-weight: 500;
    margin-top: 1px;
  }
  .exp-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-top: 4px;
  }
</style>
