---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<nav>
  <div class="nav-inner">
    <a href="#home" class="logo text-purple">AU</a>
    <div class="links">
      <a href="#home">{t("navHome")}</a>
      <a href="#experience">{t("navExperience")}</a>
      <a href="#portfolio">{t("navProjects")}</a>
      <a href="#contact">{t("navContact")}</a>
    </div>
    <div class="lang-toggle">
      <a href="/" class:list={{ active: lang === "es" }}>ES</a>
      <span class="sep">/</span>
      <a href="/en" class:list={{ active: lang === "en" }}>EN</a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 960px;
    z-index: 50;
    padding: 12px 16px;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 20px;
    border-radius: 9999px;
    border: var(--nav-border, 1px solid rgba(139,92,246,0.12));
    background: var(--nav-bg, rgba(2,4,32,0.7));
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0,0,0,0.2);
  }
  .logo {
    font-size: 1.125rem;
    font-weight: 700;
    text-decoration: none;
  }
  .links {
    display: flex;
    gap: 24px;
  }
  .links a {
    color: var(--nav-text, rgba(255,255,255,0.7));
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.15s;
  }
  .links a:hover {
    color: var(--nav-text-hover, rgb(216 180 254));
  }
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .lang-toggle a {
    color: var(--nav-text, rgba(255,255,255,0.5));
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    transition: color 0.15s;
  }
  .lang-toggle a:hover {
    color: var(--nav-text-hover, rgb(216 180 254));
  }
  .lang-toggle a.active {
    color: var(--text-heading, white);
  }
  .sep {
    color: var(--nav-text, rgba(255,255,255,0.2));
    font-size: 0.875rem;
  }
</style>
