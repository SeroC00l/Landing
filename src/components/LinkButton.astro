---
import Card from "@/components/Card.astro"

const { href } = Astro.props
---

<Card
  href={href}
  target="_blank"
  role="link"
  class="card inline-flex items-center justify-center gap-2 px-3 py-2 space-x-2 text-base text-gray-900 dark:text-white transition bg-gray-100 dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus-visible:ring-yellow-500/80 text-md hover:bg-gray-200 dark:hover:bg-gray-800 hover:border-gray-400 dark:hover:border-gray-900 group max-w-fit rounded-xl hover:text-gray-900 dark:hover:text-white focus:outline-none focus-visible:outline-none focus-visible:ring focus-visible:ring-white focus-visible:ring-offset-2 active:bg-gray-300 dark:active:bg-black"
>
  <slot />
</Card>